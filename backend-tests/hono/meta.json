{
  "name": "Hono + Web fetch handler",
  "framework": "hono",
  "mode": "direct",
  "entry": "app.js",
  "port": 3000,
  "assertions": [
    { "path": "/", "method": "GET", "expectedStatus": 200, "bodyContains": "Hono" },
    { "path": "/api/health", "expectedStatus": 200, "bodyJsonSubset": { "ok": true, "framework": "hono" } },
    { "path": "/api/users/42", "expectedStatus": 200, "bodyJsonSubset": { "user": "42", "source": "hono" } },
    { "path": "/api/echo", "method": "POST", "headers": { "content-type": "application/json" }, "body": { "k": "v" }, "expectedStatus": 200, "bodyJsonSubset": { "received": { "k": "v" } } },
    { "path": "/api/nope", "expectedStatus": 404 }
  ],
  "includeDirs": ["public"]
}
