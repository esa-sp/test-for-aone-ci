{
  "name": "Koa + app.listen",
  "framework": "koa",
  "mode": "direct",
  "entry": "server.js",
  "port": 3000,
  "assertions": [
    { "path": "/", "method": "GET", "expectedStatus": 200, "bodyContains": "Koa" },
    { "path": "/api/health", "expectedStatus": 200, "bodyJsonSubset": { "ok": true, "framework": "koa" } },
    { "path": "/api/users/42", "expectedStatus": 200, "bodyJsonSubset": { "user": "42", "source": "koa" } },
    { "path": "/api/echo", "method": "POST", "headers": { "content-type": "application/json" }, "body": { "k": "v" }, "expectedStatus": 200, "bodyJsonSubset": { "received": { "k": "v" } } },
    { "path": "/api/nope", "expectedStatus": 404 }
  ],
  "includeDirs": ["public"]
}
