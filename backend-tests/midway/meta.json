{
  "name": "Midway 3 + koa (bootstrap.js → dist/configuration.js)",
  "framework": "midway",
  "mode": "direct",
  "entry": "bootstrap.js",
  "port": 3000,
  "warmupTimeoutMs": 20000,
  "includeDirs": ["node_modules", "dist"],
  "assertions": [
    { "path": "/api/health", "expectedStatus": 200, "bodyJsonSubset": { "ok": true, "framework": "midway" } },
    { "path": "/api/users/42", "expectedStatus": 200, "bodyJsonSubset": { "user": "42", "source": "midway" } },
    { "path": "/api/echo", "method": "POST", "headers": { "content-type": "application/json" }, "body": { "k": "v" }, "expectedStatus": 200, "bodyJsonSubset": { "received": { "k": "v" } } },
    { "path": "/api/nope", "expectedStatus": 404 }
  ]
}
