{
  "name": "Nuxt 3 + node-server preset (.output/server/index.mjs)",
  "framework": "nuxtjs",
  "mode": "meta",
  "port": 3000,
  "warmupTimeoutMs": 20000,
  "assertions": [
    { "path": "/api/health", "expectedStatus": 200, "bodyJsonSubset": { "ok": true, "framework": "nuxt" } },
    { "path": "/api/users/42", "expectedStatus": 200, "bodyJsonSubset": { "user": "42", "source": "nuxt" } },
    { "path": "/api/echo", "method": "POST", "headers": { "content-type": "application/json" }, "body": { "k": "v" }, "expectedStatus": 200, "bodyJsonSubset": { "received": { "k": "v" } } },
    { "path": "/api/nope", "expectedStatus": 404 }
  ]
}
