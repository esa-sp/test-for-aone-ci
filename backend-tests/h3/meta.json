{
  "name": "H3 + toNodeListener + http.listen",
  "framework": "h3",
  "mode": "direct",
  "entry": "server.js",
  "port": 3000,
  "assertions": [
    { "path": "/api/health", "expectedStatus": 200, "bodyJsonSubset": { "ok": true, "framework": "h3" } },
    { "path": "/api/users/42", "expectedStatus": 200, "bodyJsonSubset": { "user": "42", "source": "h3" } },
    { "path": "/api/echo", "method": "POST", "headers": { "content-type": "application/json" }, "body": { "k": "v" }, "expectedStatus": 200, "bodyJsonSubset": { "received": { "k": "v" } } },
    { "path": "/api/nope", "expectedStatus": 404 }
  ]
}
